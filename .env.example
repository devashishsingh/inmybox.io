# Inmybox — Environment Variables
# Copy this file to .env and fill in the values.

# ─── Required: Database ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/inmybox?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/inmybox?schema=public"

# ─── Required: Auth ────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-random-32-char-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Required: Cron Security ──────────────────────────────────────
CRON_SECRET="generate-a-random-secret-for-cron-auth"

# ─── Optional: SMTP (email notifications) ─────────────────────────
# If not configured, lead notification emails will be silently skipped.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
ADMIN_EMAIL=""
EMAIL_FROM=""  # Falls back to SMTP_USER if empty

# ─── Optional: IMAP (DMARC report email fetching) ─────────────────
# If not configured, the email pipeline will not start.
EMAIL_IMAP_HOST="imap.gmail.com"
EMAIL_IMAP_PORT="993"
EMAIL_IMAP_USER=""
EMAIL_IMAP_PASS=""
EMAIL_FOLDER="dmarc_report"  # IMAP folder to read from

# ─── Standard (auto-detected) ─────────────────────────────────────
# NODE_ENV="development"
# PORT=3000

# ─── Feature Flags (Phase 1) ──────────────────────────────────────
# NEXT_PUBLIC_NEW_LANDING="false"    # New landing page design (client-side)
# FEATURE_BIMI_ENABLED="true"        # BIMI validation features
# FEATURE_EMAIL_PIPELINE="true"      # Email pipeline auto-fetch
# FEATURE_LEAD_CAPTURE="true"        # Public domain scan lead capture
